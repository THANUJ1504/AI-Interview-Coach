# ── Shared interview access (optional) ─────────────────────────────────────────
# Put this file at  .streamlit/secrets.toml  (remove the ".example") and fill in
# the keys you want to share. When set, EVERY user who runs an interview uses
# these keys automatically — they never have to paste their own.
#
# You can use a flat layout:
ANTHROPIC_API_KEY = "sk-ant-..."
OPENAI_API_KEY    = "sk-..."
GEMINI_API_KEY    = "AIza..."

# ...or a grouped table (either works):
# [api_keys]
# anthropic = "sk-ant-..."
# openai    = "sk-..."
# gemini    = "AIza..."
